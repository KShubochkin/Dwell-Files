#CELL 1 - load files

import pandas as pd
from pathlib import Path
from collections import defaultdict
import pyarrow.parquet as pq
import json
import gc
import re

ANN_MASTER  = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\annotation\annotation_csvs\annotation.csv")
SESSION_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\annotation\annotation_csvs_all")
PARQUET_PATH = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\raw_trajectories.parquet")
MODEL_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\RUN_feature_registry_test_20260612_173616_train-GA1-GA3-GA2-EA-H2O")
MODEL_CACHE_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\optimizer\master_feature_cache")
PROBABILITIES = MODEL_DIR / "predictions"
REGISTRY = MODEL_DIR / "larva_registry_after_split.csv"

OUTPUT_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\feature_plots")
OUTPUT_DIR.mkdir(exist_ok=True)

# extract threshold
plot_config_dir = next(p for p in (MODEL_DIR / "plots").iterdir() if p.is_dir() and "_TH" in p.name)
threshold = float(re.search(r"TH([0-9]+(?:\.[0-9]+)?)", plot_config_dir.name).group(1))

# raw trajectories 
traj_df = pd.read_parquet(PARQUET_PATH)

# larva registry
registry = pd.read_csv(REGISTRY)
status_registry = {(row.source, row.ID): row.split for _, row in registry.iterrows()}

# full annotations
ann_df = pd.concat(
    [pd.read_csv(f)
     for f in Path(SESSION_DIR).glob("*.csv")],
    ignore_index=True
)

ann_df = ann_df[ann_df["behavior"]=="dwelling"].copy()

# Model features - only load feature columns used by model
FEATURE_CONFIG = MODEL_DIR / "feature_set_config.json"  # adjust filename if needed
with open(FEATURE_CONFIG) as f:
    feature_config = json.load(f)

KEY_COLS     = ["source", "ID", "et"]
WANTED_FEATS = feature_config["all_columns"]

def safe_read(path, wanted_feats):
    schema_cols = pq.read_schema(path).names
    feat_cols   = [c for c in wanted_feats if c in schema_cols]
    return pd.read_parquet(path, columns=KEY_COLS + feat_cols)

# Group cache fragments by source — loop runs ONCE
groups = defaultdict(list)
for f in MODEL_CACHE_DIR.glob("features_*.parquet"):
    source = f.stem.replace("features_", "").split("_batch_")[0]
    groups[source].append(f)

# Reconstruct one dataframe per source
feature_dfs = {}
for source, files in groups.items():
    base_files  = [f for f in files if "_batch_" not in f.stem]
    batch_files = sorted([f for f in files if "_batch_" in f.stem])

    merged = safe_read(base_files[0], WANTED_FEATS)
    print(f"  [{source}] base shape: {merged.shape}")

    for batch_file in batch_files:
        print(f"  merging {batch_file.name}")
        batch_df    = safe_read(batch_file, WANTED_FEATS)
        cols_to_add = [c for c in batch_df.columns if c not in KEY_COLS]
        if not cols_to_add:
            print(f"    no new feature columns in {batch_file.name}, skipping")
            del batch_df
            continue
        merged = merged.merge(batch_df[KEY_COLS + cols_to_add], on=KEY_COLS, how="left")
        del batch_df
        gc.collect()

    feature_dfs[source] = merged
    print(f"  [{source}] final shape: {merged.shape}")

# Merge with probabilities
prob_file = next(PROBABILITIES.glob("*.csv"))
prob = pd.read_csv(prob_file, low_memory=False)
prob["et"] = prob["et"].astype("float32")

feat_prob_by_source = {}
for source, feat_df in feature_dfs.items():
    feat_prob_by_source[source] = feat_df.merge(prob, on=KEY_COLS, how="left")

#CELL 2 - view dfs

with pd.option_context('display.expand_frame_repr', False):
    print("traj_df","\n", traj_df.head())
    print("\nann_df", "\n", ann_df.head())
    for source, feat_df in feature_dfs.items():
        print(f"\nfeatures: {source}\n",feat_df.head())
    print("\nprobabilities\n", prob.head())
    for source, df in feat_prob_by_source.items():
        print(f"\nfeatures and probabilities: {source}\n", df.head())


