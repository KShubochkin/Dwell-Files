import pandas as pd
from pathlib import Path

ANN_MASTER  = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\annotation\annotation_csvs\annotation.csv")
SESSION_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\annotation\annotation_csvs_all")
PARQUET_PATH = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\raw_trajectories.parquet")
MODEL_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\RUN_feature_registry_test_20260610_131215_train-GA1-GA3-GA2-EA-H2O")
#MODEL_CACHE_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\feature_calculation_cache")
MODEL_CACHE_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\master_feature_cache")
PROBABILITIES = MODEL_DIR / "probabilities.csv"

OUTPUT_DIR = Path(r"C:\Users\Tomoko\Desktop\Dwelling_Project\parquet_pipeline\exported_models\feature_plots")
OUTPUT_DIR.mkdir(exist_ok=True)

# raw trajectories 
traj_df = pd.read_parquet(PARQUET_PATH)

# full annotations
ann_df = pd.concat(
    [pd.read_csv(f)
     for f in Path(SESSION_DIR).glob("*.csv")],
    ignore_index=True
)

# model infer features and probabilities
prob = pd.read_csv(PROBABILITIES)
feature_files = list(MODEL_CACHE_DIR.glob("features_*.parquet"))
feature_dfs = {}

# for f in feature_files:
#     source = f.stem.replace("features_", "").replace("_infer", "")
#     feature_dfs[source] = pd.read_parquet(f)

for f in feature_files:
    source = f.stem.replace("features_", "")
    feature_dfs[source] = pd.read_parquet(f)

feat_prob_by_source = {}
for source, feat_df in feature_dfs.items():
    merged = feat_df.merge(prob, on=["source", "ID", "et"], how="inner")
    feat_prob_by_source[source] = merged


#CELL 2 - view dfs

with pd.option_context('display.expand_frame_repr', False):
    print("traj_df","\n", traj_df.head())
    print("\nann_df", "\n", ann_df.head())
    for source, feat_df in feature_dfs.items():
        print(f"\nfeatures: {source}\n",feat_df.head())
    print("\nprobabilities\n", prob.head())



