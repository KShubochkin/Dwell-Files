# CELL 4 - Plots of first n wonderful dwelling events
import feature_plots_v3 as fp
import importlib
importlib.reload(fp)

ranked_features = pd.read_csv(MODEL_DIR /"plots"/"feature_ranking.txt", header=None)[0].tolist()
wonderful_dwells = ann_df[(ann_df["behavior"] == "dwelling") & (ann_df["tags"].fillna("").str.contains("wonderful", case=False))].sort_values(["source", "ID", "t0_sec"])

# Edit config
start_larva = None  # None (starts at beginning), 0, 1, ...
start_source = None # None, "EA", "GA1", "GA2", "GA3", "H2O"
num_features = 10 # Number of features per figure
num_larva = None    # Number of figures (None plots all larvae)
plot_name = f"top{num_features}_gini"
plot_mode = "prediction"

# first n wonderful by larva ID, only plotting top 10 GINI features in descending order
plot_features = ranked_features[:num_features]

larva_label = f"all_{len(wonderful_dwells)}" if num_larva is None else str(num_larva)
out_folder = OUTPUT_DIR / (f"Feature_plots_{plot_mode}_{larva_label}_larvae_{num_features}_features")
out_folder.mkdir(parents=True, exist_ok=True)

print(f"Found {len(wonderful_dwells)} wonderful dwellings")

if start_source is not None:
    if start_larva is None:
        wonderful_dwells = wonderful_dwells[wonderful_dwells["source"] >= start_source]
    else:
        wonderful_dwells = wonderful_dwells[(wonderful_dwells["source"] > start_source) | ((wonderful_dwells["source"] == start_source) & (wonderful_dwells["ID"] >= start_larva))]
    
if num_larva is None:
    dwells_to_plot = wonderful_dwells
else:
    dwells_to_plot = wonderful_dwells.head(num_larva)

for _, row in dwells_to_plot.iterrows():
    print(
        f"{row['source']} | "
        f"ID={row['ID']} | "
        f"start={row['t0_sec']:.3f}"
    )

    fp.plot_dwelling_segment(
        ann_df = ann_df,
        traj_df = traj_df,
        feat_prob_by_source = feat_prob_by_source,
        output_dir = out_folder,
        status_registry = status_registry,
        source=row["source"],
        larva_id=row["ID"],
        start_time=row["t0_sec"],
        feature_list=plot_features,
        plot_name=plot_name,
        threshold = threshold,
        plot_mode = plot_mode,
    )

n_plotted = len(dwells_to_plot)
print(f"\nDone! All {n_plotted} plots saved -> {OUTPUT_DIR}")
