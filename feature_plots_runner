    "# feature_plots_runner\n",
    "\n",
    "#CELL 1 - load files\n",
    "\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "\n",
    "ANN_MASTER  = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\annotation\\annotation_csvs\\annotation.csv\")\n",
    "SESSION_DIR = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\annotation\\annotation_csvs_all\")\n",
    "PARQUET_PATH = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\parquet_pipeline\\raw_trajectories.parquet\")\n",
    "MODEL_DIR = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\parquet_pipeline\\exported_models\\RUN_feature_registry_test_20260610_131215_train-GA1-GA3-GA2-EA-H2O\")\n",
    "MODEL_CACHE_DIR = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\parquet_pipeline\\exported_models\\feature_calculation_cache\")\n",
    "PROBABILITIES = MODEL_DIR / \"probabilities.csv\"\n",
    "\n",
    "OUTPUT_DIR = Path(r\"C:\\Users\\Tomoko\\Desktop\\Dwelling_Project\\parquet_pipeline\\exported_models\\feature_plots\")\n",
    "OUTPUT_DIR.mkdir(exist_ok=True)\n",
    "\n",
    "# raw trajectories \n",
    "traj_df = pd.read_parquet(PARQUET_PATH)\n",
    "\n",
    "# full annotations\n",
    "ann_df = pd.concat(\n",
    "    [pd.read_csv(f)\n",
    "     for f in Path(SESSION_DIR).glob(\"*.csv\")],\n",
    "    ignore_index=True\n",
    ")\n",
    "\n",
    "# model infer features and probabilities\n",
    "prob = pd.read_csv(PROBABILITIES)\n",
    "feature_files = list(MODEL_CACHE_DIR.glob(\"features_*_infer.parquet\"))\n",
    "feature_dfs = {}\n",
    "\n",
    "for f in feature_files:\n",
    "    source = f.stem.replace(\"features_\", \"\").replace(\"_infer\", \"\")\n",
    "    feature_dfs[source] = pd.read_parquet(f)\n",
    "\n",
    "feat_prob_by_source = {}\n",
    "for source, feat_df in feature_dfs.items():\n",
    "    merged = feat_df.merge(prob, on=[\"source\", \"ID\", \"et\"], how=\"inner\")\n",
    "    feat_prob_by_source[source] = merged\n"
   ]
