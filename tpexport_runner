@dataclass
class PostProcessConfig:
    median_filter: float = 5.166667
    threshold: float = 0.5
    gap_fill_size: float = 5.5
    minimum_dwell_length: float = 4.5
    def predict(self,probs):
        # apply median filter
        smoothed_probs = median_filter(probs, size=int(self.median_filter * 6))
        # apply threshold
        preds = (smoothed_probs > self.threshold).astype(int)
        
        close_size = int(self.gap_fill_size * 6)
        open_size = int(self.minimum_dwell_length * 6)
        pad_len = max(close_size, open_size)
        preds_padded = np.pad(preds, pad_width=pad_len, mode='edge')
        
        preds_padded = binary_closing(preds_padded, structure=np.ones(close_size)).astype(int)
        preds_padded = binary_opening(preds_padded, structure=np.ones(open_size)).astype(int)
        
        preds = preds_padded[pad_len:-pad_len]
  
        return preds
        
    def get_IDstr(self):
        return f"MF{self.median_filter}_TH{self.threshold}_GC{self.gap_fill_size}_GO{self.minimum_dwell_length}"
    
ppc = PostProcessConfig(MF,TH,GC,GO)

